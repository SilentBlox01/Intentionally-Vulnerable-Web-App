<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="error-page">
  <div class="error-content">
    <h1>Error</h1>
    <p style="white-space: pre-wrap; text-align: left; background: var(--bg-body); padding: 16px; border-radius: var(--radius-sm); font-family: 'SF Mono', monospace; font-size: 0.82rem; max-width: 560px; margin: 0 auto 20px; border: 1px solid var(--border); color: var(--text-secondary);"><%= message %></p>
    <div style="display: flex; gap: 10px; justify-content: center;">
      <a href="/dashboard" class="btn btn-primary btn-sm">Go to Dashboard</a>
      <a href="/login" class="btn btn-secondary btn-sm">Sign In</a>
    </div>
  </div>
</div>
</body>
</html>
