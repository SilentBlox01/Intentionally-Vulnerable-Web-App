<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <meta name="description" content="Open a new account with SecureTrust Bank. Quick, secure, and easy.">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="auth-wrapper">
  <div class="auth-hero">
    <div class="hero-content">
      <div class="hero-logo">
        <div class="hero-logo-icon">
          <svg viewBox="0 0 24 24"><path d="M4 10v7h3v-7H4zm6 0v7h3v-7h-3zM2 22h19v-3H2v3zm14-12v7h3v-7h-3zm-4.5-9L2 6v2h19V6l-9.5-5z"/></svg>
        </div>
        <span>SecureTrust Bank</span>
      </div>
      <h2>Open your account in minutes.</h2>
      <p>Join thousands of customers who trust SecureTrust for their personal and business banking needs. Start with a free checking account today.</p>
      <ul class="hero-features">
        <li>
          <span class="check-icon"><svg viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg></span>
          No monthly maintenance fees
        </li>
        <li>
          <span class="check-icon"><svg viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg></span>
          Free debit card & mobile banking
        </li>
        <li>
          <span class="check-icon"><svg viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg></span>
          Earn up to 4.5% APY on savings
        </li>
      </ul>
    </div>
  </div>

  <div class="auth-form-side">
    <div class="auth-form-header">
      <h1>Create Account</h1>
      <p>Open your SecureTrust Bank account</p>
    </div>

    <% if (error) { %>
      <div class="alert alert-danger">⚠ <%= error %></div>
    <% } %>
    <% if (success) { %>
      <div class="alert alert-success">✓ <%= success %></div>
    <% } %>

    <form method="POST" action="/register" id="registerForm">
      <div class="form-row">
        <div class="form-group">
          <label for="username">Username</label>
          <input type="text" id="username" name="username" class="form-input" placeholder="Choose a username" required>
        </div>
        <div class="form-group">
          <label for="password">Password</label>
          <input type="password" id="password" name="password" class="form-input" placeholder="Create a password" required>
        </div>
      </div>

      <div class="form-group">
        <label for="full_name">Full Name</label>
        <input type="text" id="full_name" name="full_name" class="form-input" placeholder="As it appears on your ID" required>
      </div>

      <div class="form-group">
        <label for="email">Email Address</label>
        <input type="email" id="email" name="email" class="form-input" placeholder="your@email.com" required>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="phone">Phone Number</label>
          <input type="text" id="phone" name="phone" class="form-input" placeholder="+1 (555) 000-0000">
        </div>
        <div class="form-group">
          <label for="address">Mailing Address</label>
          <input type="text" id="address" name="address" class="form-input" placeholder="Street address">
        </div>
      </div>

      
      <input type="hidden" name="role" value="user" id="roleField">

      <button type="submit" class="btn btn-primary btn-block" style="margin-top: 4px;">Open Account</button>
    </form>

    <div class="auth-footer">
      <p>Already have an account? <a href="/login">Sign in</a></p>
    </div>

    <div class="auth-trust">
      <span>🔒 SSL Secured</span>
      <span>🏦 FDIC Insured</span>
    </div>
  </div>
</div>
<script src="/js/app.js"></script>
</body>
</html>
